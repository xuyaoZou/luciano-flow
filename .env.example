# ============================================
# Luciano Platform Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# === Database ===
POSTGRES_DB=luciano
POSTGRES_USER=luciano
POSTGRES_PASSWORD=change-me-in-production

# === Backend ===
# Database connection (auto-filled from above when using docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/luciano
SPRING_DATASOURCE_USERNAME=luciano
SPRING_DATASOURCE_PASSWORD=change-me-in-production

# JWT secret (must be at least 32 characters)
LUCIANO_JWT_SECRET=change-this-to-a-random-string-at-least-32-chars-long

# Media storage path
MEDIA_STORAGE_PATH=./uploads/media

# === AI Model API Keys ===
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
ARK_API_KEY=

# === Frontend ===
NUXT_PUBLIC_API_BASE=http://localhost:8090/api/v1